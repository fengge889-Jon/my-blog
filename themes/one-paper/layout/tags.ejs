<% 
  const tags = site.tags;
%>
<div class="tags-container">
  <h1>Tags</h1>
  <% if (tags.length > 0) { %>
    <% tags.forEach(tag => { %>
      <div class="tag-item" style="margin: 10px 0;">
        <a href="<%= config.root %><%= tag.path %>"><%= tag.name %></a>
        <span style="margin-left: 10px;">(<%= tag.length %>)</span>
      </div>
    <% }) %>
  <% } else { %>
    <p>No tags yet.</p>
  <% } %>
</div>
